rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Resumes: Open to everyone (for job applicants)
    match /resumes/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Everything else (Franchises, Projects, Testimonials): Admin only
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
